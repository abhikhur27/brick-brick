rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── TEAM WORKSPACE ──────────────────────────────────────────────────────
    // Pipeline, tasks, and decisions are only accessible to authenticated users.
    match /pipeline/{docId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    match /decisions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── CONTACT FORM ────────────────────────────────────────────────────────
    // contact_submissions: public can create (form submits without login).
    // Only authenticated team members can read.
    match /contact_submissions/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // mail: written by the contact form (public create) so the Firebase
    // "Trigger Email from Firestore" extension picks it up and sends email.
    // No reads needed from client side.
    match /mail/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
