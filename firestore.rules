rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All three workspace collections are readable and writable
    // only by authenticated users.  No public access.
    match /pipeline/{docId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    match /decisions/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
