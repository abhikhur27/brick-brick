rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── TEAM WORKSPACE ──────────────────────────────────────────────────────
    // All three workspace collections require Firebase Authentication.
    // No unauthenticated access.
    match /pipeline/{docId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    match /decisions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── CONTACT FORM SUBMISSIONS ────────────────────────────────────────────
    // Public visitors can CREATE a submission (the contact form).
    // Only authenticated team members can read or delete records.
    // No Cloud Functions, no Secret Manager, no Blaze plan required.
    match /contact_submissions/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // NOTE: The `mail` collection rule has been removed.
    // The Firebase "Trigger Email" extension required Blaze plan / Secret Manager.
    // Email is now handled by Web3Forms (static-site-friendly, no backend needed).
  }
}
