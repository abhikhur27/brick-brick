rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAuthEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.size() > 0;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function hasUserRecord() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return hasUserRecord()
        && (userRole() == "admin" || userRole() == "super_admin");
    }

    function isSuperAdmin() {
      return hasUserRecord()
        && userRole() == "super_admin";
    }

    function isClient() {
      return hasUserRecord()
        && userRole() == "client"
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.disabled != true;
    }

    function myClientId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId;
    }

    function hasOwnProvision() {
      return hasAuthEmail()
        && exists(/databases/$(database)/documents/login_provisioning/$(authEmail()));
    }

    function ownProvisionIsActive() {
      return hasOwnProvision()
        && get(/databases/$(database)/documents/login_provisioning/$(authEmail())).data.status != "disabled";
    }

    function ownProvisionRole() {
      return get(/databases/$(database)/documents/login_provisioning/$(authEmail())).data.role;
    }

    function ownProvisionClientId() {
      return get(/databases/$(database)/documents/login_provisioning/$(authEmail())).data.clientId;
    }

    function ownProvisionHasClientId() {
      return get(/databases/$(database)/documents/login_provisioning/$(authEmail())).data.keys().hasAny(["clientId"]);
    }

    function canMatchClientIdentity(clientId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/clients/$(clientId))
        && (
          get(/databases/$(database)/documents/clients/$(clientId)).data.authUid == request.auth.uid
          || (hasAuthEmail() && get(/databases/$(database)/documents/clients/$(clientId)).data.email == authEmail())
          || (hasAuthEmail() && get(/databases/$(database)/documents/clients/$(clientId)).data.emailLower == authEmail())
        );
    }

    function isValidBootstrapPayload() {
      return hasAuthEmail()
        && request.resource.data.keys().hasOnly([
          "role",
          "clientId",
          "email",
          "name",
          "notes",
          "disabled",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.role is string
        && request.resource.data.clientId is string
        && request.resource.data.email is string
        && request.resource.data.email == authEmail()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          !request.resource.data.keys().hasAny(["disabled"])
          || request.resource.data.disabled is bool
        )
        && (
          !request.resource.data.keys().hasAny(["disabled"])
          || request.resource.data.disabled == false
        );
    }

    function canBootstrapClientRole() {
      return request.resource.data.role == "client"
        && request.resource.data.clientId.size() > 0
        && canMatchClientIdentity(request.resource.data.clientId)
        && hasOwnProvision()
        && ownProvisionIsActive()
        && ownProvisionRole() == "client"
        && (
          !ownProvisionHasClientId()
          || ownProvisionClientId() == ""
          || ownProvisionClientId() == request.resource.data.clientId
        );
    }

    function canBootstrapTeamRole() {
      return (request.resource.data.role == "admin" || request.resource.data.role == "super_admin")
        && hasOwnProvision()
        && ownProvisionIsActive()
        && ownProvisionRole() == request.resource.data.role;
    }

    function isSelfBootstrapCreate(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/users/$(uid))
        && isValidBootstrapPayload()
        && (canBootstrapClientRole() || canBootstrapTeamRole());
    }

    // Allow public website form to create only constrained lead records.
    function isAllowedService(svc) {
      return svc == "AI Workflow"
        || svc == "Website Build"
        || svc == "Other";
    }

    function isPublicPipelineLeadCreate() {
      return request.auth == null
        && request.resource.data.keys().hasOnly([
          "title",
          "company",
          "contact",
          "service",
          "status",
          "note",
          "source",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.company is string
        && request.resource.data.company.size() <= 120
        && request.resource.data.contact is string
        && request.resource.data.contact.size() <= 200
        && isAllowedService(request.resource.data["service"])
        && request.resource.data.status == "leads"
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 4000
        && request.resource.data.source == "website-contact-form"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isAllowedRequestCategory(cat) {
      return cat == "issue"
        || cat == "website_change"
        || cat == "workflow_tweak"
        || cat == "automation_adjustment"
        || cat == "content_update"
        || cat == "general_support";
    }

    function isAllowedRequestPriority(priority) {
      return priority == "low"
        || priority == "normal"
        || priority == "high";
    }

    function isClientRequestCreate() {
      return isClient()
        && request.resource.data.keys().hasOnly([
          "clientId",
          "clientName",
          "clientEmail",
          "title",
          "description",
          "category",
          "priority",
          "status",
          "createdAt",
          "updatedAt",
          "source"
        ])
        && request.resource.data.clientId == myClientId()
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0
        && request.resource.data.clientName.size() <= 160
        && request.resource.data.clientEmail is string
        && request.resource.data.clientEmail.size() <= 200
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 140
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 4000
        && isAllowedRequestCategory(request.resource.data.category)
        && isAllowedRequestPriority(request.resource.data.priority)
        && request.resource.data.status == "submitted"
        && request.resource.data.source == "client-dashboard"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isPublicContactSubmissionCreate() {
      return request.auth == null
        && request.resource.data.keys().hasOnly([
          "name",
          "email",
          "phone",
          "company",
          "message",
          "submittedAt",
          "source",
          "pipelineId",
          "importedToPipelineAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 160
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 40
        && request.resource.data.company is string
        && request.resource.data.company.size() <= 160
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 4000
        && request.resource.data.source == "website-contact-form"
        && request.resource.data.pipelineId is string
        && request.resource.data.pipelineId.size() > 0
        && request.resource.data.pipelineId.size() <= 200
        && request.resource.data.submittedAt is timestamp
        && request.resource.data.importedToPipelineAt is timestamp;
    }

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isAdmin() || isSelfBootstrapCreate(uid);
      allow update, delete: if isAdmin();
    }

    match /login_provisioning/{provisionId} {
      allow read: if isSuperAdmin() || (hasAuthEmail() && provisionId == authEmail());
      allow create, update, delete: if isSuperAdmin();
    }

    // INTERNAL TEAM WORKSPACE
    match /pipeline/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || isPublicPipelineLeadCreate();
    }

    match /lead_research_imports/{docId} {
      allow read, write: if isAdmin();
    }

    match /tasks/{docId} {
      allow read, write: if isAdmin();
    }

    match /decisions/{docId} {
      allow read, write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAdmin()
        || (isClient() && myClientId() == clientId)
        || (
          !hasUserRecord()
          && hasOwnProvision()
          && ownProvisionIsActive()
          && ownProvisionRole() == "client"
          && (
            !ownProvisionHasClientId()
            || ownProvisionClientId() == ""
            || ownProvisionClientId() == clientId
          )
          && canMatchClientIdentity(clientId)
        );
      allow create, update, delete: if isAdmin();
    }

    match /client_requests/{requestId} {
      allow read: if isAdmin() || (isClient() && resource.data.clientId == myClientId());
      allow create: if isAdmin() || isClientRequestCreate();
      allow update, delete: if isAdmin();
    }

    match /client_flow/{docId} {
      allow read, write: if isAdmin();
    }

    // CONTACT FORM SUBMISSIONS
    // Public visitors can create a submission.
    // Team admins can read/update/delete.
    match /contact_submissions/{docId} {
      allow create: if isPublicContactSubmissionCreate() || isAdmin();
      allow read, update, delete: if isAdmin();
    }
  }
}
